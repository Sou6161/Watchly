# Neon Postgres. DATABASE_URL is the pooled connection string (used at runtime);
# DIRECT_URL is the unpooled one (used by `prisma db push` / migrations).
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/watchly?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/watchly?sslmode=require"

# Must differ from each other. Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="30d"

PORT=4000

# Needed from Feature 2 (catalog sync) onward.
TMDB_API_KEY=""
