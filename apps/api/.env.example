# --- Database (Neon in production) ---------------------------------------
#
# DATABASE_URL is the POOLED connection (used at runtime). Neon's pooler is
# PgBouncer in transaction mode, which does not support prepared statements —
# Prisma uses them, so `?pgbouncer=true` is REQUIRED or queries start failing
# under concurrency. `connection_limit=1` keeps a free instance from exhausting
# Neon's connection quota.
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/watchly?sslmode=require&pgbouncer=true&connection_limit=1"

# DIRECT_URL is the UNPOOLED connection. Migrations need a real session (they take
# advisory locks and run DDL), which cannot go through a transaction pooler.
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/watchly?sslmode=require"

# --- Auth -----------------------------------------------------------------
#
# Must DIFFER from each other — sharing one secret would let an access token be
# replayed as a refresh token. The API refuses to boot if they match or are short.
# Generate with: openssl rand -hex 32
# Rotating either signs every user out.
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="30d"

# --- Server ---------------------------------------------------------------
# Render injects PORT automatically; this is only the local default.
PORT=4000

# --- TMDB (catalog sync) --------------------------------------------------
# Either the v4 read access token (a JWT, starts "eyJ") or the v3 API key.
# The client detects which one you gave it.
TMDB_API_KEY=""

# --- Nightly catalog sync trigger ----------------------------------------
# Shared secret for POST /internal/sync-catalog. Must match the GitHub Actions
# secret of the same name. Without it, the endpoint refuses to run at all.
# Generate with: openssl rand -hex 24
CRON_SECRET=""
