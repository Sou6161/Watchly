{
  "name": "@watchly/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "sync": "tsx src/jobs/sync-catalog.ts",
    "tmdb:providers": "tsx src/scripts/check-providers.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/apps/api/src/index.js",
    "db:deploy": "prisma migrate deploy",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "@watchly/shared": "*",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/supertest": "^7.2.0",
    "prisma": "^6.3.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  }
}
