{
  "expo": {
    "name": "Watchly",
    "slug": "watchly",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "watchly",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A0F2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.watchly.app",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "nflx",
          "aiv",
          "hotstar",
          "sonyliv",
          "zee5",
          "videos",
          "disneyplus"
        ]
      }
    },
    "android": {
      "package": "com.watchly.app",
      "queries": [
        {
          "package": "com.netflix.mediaclient"
        },
        {
          "package": "com.amazon.avod.thirdpartyclient"
        },
        {
          "package": "in.startv.hotstar"
        },
        {
          "package": "com.sonyliv"
        },
        {
          "package": "com.graymatrix.did"
        },
        {
          "package": "com.apple.atve.androidtv.appletv"
        },
        {
          "package": "com.disney.disneyplus"
        },
        {
          "package": "com.crunchyroll.crunchyroid"
        },
        {
          "package": "com.mubi"
        },
        {
          "package": "com.suntv.sunnxt"
        },
        {
          "package": "com.valuelabs.aha"
        },
        {
          "package": "com.viewlift.hoichoi"
        },
        {
          "package": "com.lionsgateplay.videoapp"
        },
        {
          "package": "com.hulu.plus"
        },
        {
          "package": "com.wbd.stream"
        },
        {
          "package": "com.peacocktv.peacockandroid"
        },
        {
          "package": "com.cbs.ott"
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#1A0F2E",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Watchly uses the camera to scan your partner\u2019s session QR code."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
